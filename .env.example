# ══════════════════════════════════════════════════════════════
#  SIGEGEN - Variables de Entorno (.env.example)
#  Copie este archivo como .env y complete los valores.
# ══════════════════════════════════════════════════════════════

# ── MQTT Configuration ───────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=sigegen/+/+/datos
MQTT_QOS=1

# ── InfluxDB Configuration ──────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=          # Token de autenticación de InfluxDB
INFLUXDB_ORG=sigegen
INFLUXDB_BUCKET=generadores
INFLUXDB_TIMEOUT_MS=5000

# ── SQLite (fallback cuando InfluxDB no está disponible) ────
# SQLITE_DB_PATH=        # Dejar vacío para usar la ruta por defecto (raíz/sigegen.db)

# ── Backend ──────────────────────────────────────────────────
BACKEND_PORT=8001
LOG_LEVEL=INFO

# ── Cache ────────────────────────────────────────────────────
CACHE_TTL_SECONDS=60
CACHE_MAX_SIZE=128
