# MQTT Configuration (por ahora usamos localhost para pruebas)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=sigegen/+/+/datos
MQTT_QOS=1

# InfluxDB Configuration (por ahora deshabilitado para pruebas)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=sigegen
INFLUXDB_BUCKET=generadores
INFLUXDB_TIMEOUT_MS=5000

# SQLite fallback (dejar vacío para ruta por defecto)
# SQLITE_DB_PATH=

# Backend
BACKEND_PORT=8001

# Logging
LOG_LEVEL=INFO

# Cache
CACHE_TTL_SECONDS=60
CACHE_MAX_SIZE=128
